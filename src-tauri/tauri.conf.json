{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CrystalMail",
  "version": "0.4.1",
  "identifier": "com.melchinger.crystalmail",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:14210",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "CrystalMail",
        "width": 1280,
        "height": 820,
        "minWidth": 800,
        "minHeight": 500,
        "center": true,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: https: http:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost; frame-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'none'",
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Thomas Melchinger",
    "homepage": "https://github.com/melchinger/crystalmail",
    "copyright": "Copyright (c) 2026 Thomas Melchinger",
    "category": "Productivity",
    "shortDescription": "Clean, fast, local-first IMAP mail client.",
    "longDescription": "CrystalMail is a clean, fast, local-first IMAP mail client with workflow automation, optional pi-AI integration, encrypted-at-rest SQLite storage, and a focused inbox-zero UX.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "librsvg2-2"
        ]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": []
    }
  }
}
